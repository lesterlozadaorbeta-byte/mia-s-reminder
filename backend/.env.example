# ============================================
# AI Personal Assistant - Environment Config
# ============================================
# Copy this to .env and fill in your values.
# For production, set APP_ENV=production and DEBUG=false

# --- Application ---
APP_NAME=Mia's Reminder
APP_ENV=development
# Set to "production" for live deployment
DEBUG=true
# IMPORTANT: Generate a strong random key for production!
# Run: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-this-in-production-generate-a-real-key
API_VERSION=v1

# --- Database (PostgreSQL) ---
# Railway provides DATABASE_URL automatically when you add PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_assistant
DATABASE_SYNC_URL=postgresql://postgres:postgres@localhost:5432/ai_assistant

# --- Redis ---
# Railway provides REDIS_URL automatically when you add Redis
REDIS_URL=redis://localhost:6379/0

# --- Firebase (for Google/Apple/Facebook login) ---
# 1. Go to console.firebase.google.com
# 2. Create a project
# 3. Go to Project Settings > Service Accounts > Generate New Private Key
# 4. Save the JSON file and set the path here
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json
FIREBASE_PROJECT_ID=your-firebase-project-id

# --- OpenAI (for AI chat) ---
# 1. Go to platform.openai.com
# 2. Create API key
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096

# --- Telegram Bot ---
# 1. Open Telegram, search for @BotFather
# 2. Send /newbot and follow the steps
# 3. Copy the token here
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# Set this to your backend's public URL + /api/v1/telegram/webhook
TELEGRAM_WEBHOOK_URL=https://your-backend.railway.app/api/v1/telegram/webhook

# --- Firebase Cloud Messaging (Push Notifications) ---
# Uses the same Firebase credentials as above
FCM_SERVER_KEY=your-fcm-server-key

# --- CORS ---
# Comma-separated list of allowed frontend origins
# Set to your Vercel domain in production
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,https://your-app.vercel.app

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60

# --- JWT ---
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
